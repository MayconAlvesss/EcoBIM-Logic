<Window x:Class="Aura.Revit.UI.DashboardView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Aura CORE | LCA Dashboard"
        Height="760" Width="1150"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Foreground="White">

    <!-- The main container with drop shadow to make the floating UI pop -->
    <Border Background="Transparent" 
            Margin="10"
            CornerRadius="8"
            BorderBrush="#444" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="15" ShadowDepth="5" Opacity="0.5"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Top Control Bar (Draggable Title Bar) -->
            <Border Grid.Row="0" Background="#111111" Padding="15,10"
                    CornerRadius="8,8,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <DockPanel>
                    <!-- Logo / Title -->
                    <TextBlock DockPanel.Dock="Left"
                               Text="AURA CORE"
                               FontSize="16" FontWeight="Black"
                               Foreground="#00d4a8"
                               VerticalAlignment="Center"
                               Margin="0,0,20,0"/>

                    <TextBlock Text="{Binding StatusMessage}"
                               VerticalAlignment="Center"
                               Foreground="#aaaaaa"
                               FontSize="12"
                               DockPanel.Dock="Left"/>

                    <!-- Buttons on the right -->
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">

                        <!-- Clear Heatmap -->
                        <Button Content="✕ Clear"
                                Command="{Binding ClearHeatmapCommand}"
                                Margin="0,0,10,0" Padding="12,6"
                                Background="#cc3333" Foreground="White"
                                BorderThickness="0" Cursor="Hand"
                                FontSize="12" ToolTip="Clear colours from the 3D view"/>

                        <!-- Preview Heatmap -->
                        <Button Content="⬛ Context Preview"
                                Command="{Binding PreviewHeatmapCommand}"
                                Margin="0,0,10,0" Padding="12,6"
                                Background="#2a5298" Foreground="White"
                                BorderThickness="0" Cursor="Hand"
                                FontSize="12" ToolTip="Colour elements by category"/>

                        <!-- Full Sync -->
                        <Button Content="⚡ Sync &amp; Analyze"
                                Command="{Binding SyncCommand}"
                                Margin="0,0,15,0" Padding="15,6"
                                Background="#00a878" Foreground="White"
                                BorderThickness="0" Cursor="Hand"
                                FontSize="12" FontWeight="Bold"/>

                        <!-- Close Button -->
                        <Button Content="✖" 
                                Click="CloseButton_Click"
                                Background="Transparent" Foreground="#888"
                                BorderThickness="0" Cursor="Hand"
                                FontSize="14" VerticalAlignment="Center"
                                ToolTip="Close Dashboard"/>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Web Dashboard area (Background must be transparent down to the WebView2) -->
            <Border Grid.Row="1" Background="Transparent" CornerRadius="0,0,8,8" ClipToBounds="True">
                <wv2:WebView2 Name="MainWebView"/>
            </Border>
        </Grid>
    </Border>
</Window>